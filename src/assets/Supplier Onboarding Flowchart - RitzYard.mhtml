verflow: hidden; }

.header { background: rgb(30, 58, 95); color: rgb(255, 255, 255); padding: =
24px; text-align: center; }

.header h1 { font-size: 28px; margin-bottom: 8px; }

.header p { opacity: 0.8; font-size: 14px; }

